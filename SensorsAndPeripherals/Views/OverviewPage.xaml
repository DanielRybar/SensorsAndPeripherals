<?xml version="1.0" encoding="utf-8" ?>
<abstract:ApplicationPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SensorsAndPeripherals.Views.OverviewPage"
             xmlns:abstract="clr-namespace:SensorsAndPeripherals.Views.Abstract"
             Title="{StaticResource OverviewTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="30">
            <Button Text="Načíst senzory" Command="{Binding GetSensorsCommand}"/>

            <CollectionView ItemsSource="{Binding Sensors}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="10">
                            <Label Text="{Binding Name}" FontAttributes="Bold" />
                            <Label Text="{Binding Vendor}" TextColor="Gray" />
                            <Label Text="{Binding StringType}" FontSize="Small" />
                            <BoxView HeightRequest="1" Color="LightGray" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</abstract:ApplicationPage>
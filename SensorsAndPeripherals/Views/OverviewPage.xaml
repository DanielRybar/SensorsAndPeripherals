<?xml version="1.0" encoding="utf-8" ?>
<abstract:ApplicationPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SensorsAndPeripherals.Views.OverviewPage"
             xmlns:abstract="clr-namespace:SensorsAndPeripherals.Views.Abstract"
             xmlns:vm="clr-namespace:SensorsAndPeripherals.ViewModels"
             xmlns:models="clr-namespace:SensorsAndPeripherals.Models"
             x:DataType="vm:OverviewViewModel"
             IsWorking="{Binding IsWorking}"
             Title="{StaticResource OverviewTitle}">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="10">
        <Button Text="{StaticResource LoadSensors}" Command="{Binding GetSensorsCommand}" Style="{StaticResource HorizontalFilledButton}" />

        <CollectionView x:Name="MainCollectionView" Grid.Row="1" ItemsSource="{Binding Sensors}" Style="{StaticResource SensorCollectionView}">
            <CollectionView.EmptyView>
                <Grid HeightRequest="{Binding Source={x:Reference MainCollectionView}, Path=Height}">
                    <Label Text="{StaticResource EmptyViewText}" Style="{StaticResource DataGuardEmptyLabel}" />
                </Grid>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SensorInfo">
                    <Border Style="{StaticResource SensorOverviewBorder}">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding Name}" Style="{StaticResource CollectionViewItemTitle}" />
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="{StaticResource SensorVendor}" FontAttributes="Bold" />
                                <Label Text="{Binding Vendor}" LineBreakMode="TailTruncation" />
                            </HorizontalStackLayout>
                            <Grid ColumnDefinitions="*, *">
                                <Label Grid.Column="0" Text="{Binding Version, StringFormat='Verze: {0}'}"  FontSize="Small" />
                                <Label Grid.Column="1" Text="{Binding Power, StringFormat='Spotřeba: {0:F3} mA'}" FontSize="Small" HorizontalOptions="End" />
                            </Grid>
                            <Label Text="{Binding StringType}" Style="{StaticResource CollectionViewItemType}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</abstract:ApplicationPage>